---
import { getCollection } from 'astro:content';
import PostCard from '@/components/blog/PostCard.astro';
import Footer from '@/components/navigation/Footer.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import IconArrowRight from '~icons/tabler/arrow-right';

const allPosts = await getCollection('blog');

const posts = allPosts
  .filter(({ data: { draft = false } }) => !draft)
  .sort(({ data: { date: dateA } }, { data: { date: dateB } }) => dateB.valueOf() - dateA.valueOf())
  .slice(0, 20);

const pageDescription =
  '王苏洋的个人技术博客，专注于前端开发、Web 技术实践和架构设计。分享 Astro、React、TypeScript、TailwindCSS 等现代 Web 技术的开发经验、最佳实践和深度思考。';
---

<BaseLayout description={pageDescription}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <main class="space-y-0">
      {posts.length > 0 ? (
          posts.map((post, index) => (
            <div
              class="animate-in fade-in slide-in-from-bottom-4 duration-700"
              style={{
                animationDelay: `${index * 50}ms`,
                animationFillMode: 'both',
              }}
            >
              <PostCard post={post} />
              {index < posts.length - 1 && <div class="border-t border-dashed border-zinc-100 dark:border-zinc-800" />}
            </div>
          ))
        ) : (
          <div class="p-8 text-center bg-zinc-50 dark:bg-zinc-900 rounded-lg border border-zinc-200 dark:border-zinc-800">
            <p class="text-lg text-zinc-600 dark:text-zinc-400">暂无发布的文章</p>
          </div>
        )}
    </main>

    {posts.length > 0 && (
      <div class="my-12 flex justify-center">
        <a
          href="/archive"
          class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                 bg-white dark:bg-zinc-900
                 border border-zinc-200 dark:border-zinc-700
                 hover:bg-zinc-100 dark:hover:bg-zinc-800
                 text-zinc-600 dark:text-zinc-400
                 transition-colors group"
        >
          <span class="text-sm font-medium">查看所有文章</span>
          <IconArrowRight class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
        </a>

        <p class="md:hidden text-sm text-zinc-500 dark:text-zinc-400">
          更多文章，请在归档中查看
        </p>
      </div>
    )}
  </div>

  <Footer client:load />

  <script>
    import { prefetch } from 'astro:prefetch';

    prefetch('/archive', { ignoreSlowConnection: true });
    prefetch('/newsletter', { ignoreSlowConnection: true });
    prefetch('/about', { ignoreSlowConnection: true });
  </script>
</BaseLayout>
